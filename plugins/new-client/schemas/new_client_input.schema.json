        },
        "enhanced_review_interval_months": {
          "enum": [null, 6, 12]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "section_b_mode": {
                "const": "full"
              }
            }
          },
          "then": {
            "properties": {
              "section_b_exclusion_confirmation": {
                "type": "null"
              },
              "factors_b": {
                "items": {
                  "properties": {
                    "score": {
                      "type": "number",
                      "minimum": 1,
                      "maximum": 4
                    }
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "section_b_mode": {
                "const": "excluded_confirmed"
              }
            }
          },
          "then": {
            "properties": {
              "section_b_exclusion_confirmation": {
                "$ref": "#/$defs/section_b_confirmation"
              },
              "factors_b": {
                "items": {
                  "properties": {
                    "score": {
                      "type": "null"
                    }
                  }
                }
              }
            }
          }
        }
      ]
