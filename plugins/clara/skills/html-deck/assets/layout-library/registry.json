{
  "schema_version": "clara.html_deck_layout_registry.v1",
  "css": "layouts.css",
  "layouts": [
    {
      "id": "editorial-cover",
      "name": "Editorial cover",
      "narrative_role": "Open on the governing decision or tension.",
      "description": "A restrained title page with a one-line promise and speaker identity.",
      "slide_class": "slide--top",
      "tone_options": ["light", "dark"],
      "headline_slot": "title",
      "density_budget": {"max_total_words": 48, "max_items": 0},
      "typography_budget": {"headline_max_chars": 92, "headline_max_lines": 3, "body_min_px": 20},
      "fragment_support": {"mode": "none", "max_fragments": 0},
      "template": "templates/editorial-cover.html",
      "slots": {
        "eyebrow": {"type": "text", "required": true, "max_chars": 64},
        "title": {"type": "text", "required": true, "max_chars": 92},
        "subtitle": {"type": "text", "required": true, "max_chars": 180},
        "author": {"type": "text", "required": false, "max_chars": 100},
        "source_note": {"type": "text", "required": false, "max_chars": 180}
      }
    },
    {
      "id": "assertion",
      "name": "Assertion",
      "narrative_role": "State the governing claim and its consequence.",
      "description": "An editorial statement slide with one implication and one qualification.",
      "slide_class": "slide--center",
      "tone_options": ["light", "dark"],
      "headline_slot": "title",
      "density_budget": {"max_total_words": 78, "max_items": 0},
      "typography_budget": {"headline_max_chars": 115, "headline_max_lines": 4, "body_min_px": 20},
      "fragment_support": {"mode": "none", "max_fragments": 0},
      "template": "templates/assertion.html",
      "slots": {
        "eyebrow": {"type": "text", "required": true, "max_chars": 64},
        "title": {"type": "text", "required": true, "max_chars": 115},
        "body": {"type": "text", "required": true, "max_chars": 300},
        "implication_label": {"type": "text", "required": false, "max_chars": 48},
        "implication": {"type": "text", "required": false, "max_chars": 180},
        "source_note": {"type": "text", "required": false, "max_chars": 180}
      }
    },
    {
      "id": "chapter-transition",
      "name": "Chapter transition",
      "narrative_role": "Reorient the room before a material change in the argument.",
      "description": "A quiet transition with a chapter assertion rather than a table-of-contents label.",
      "slide_class": "slide--center",
      "tone_options": ["light", "dark"],
      "headline_slot": "title",
      "density_budget": {"max_total_words": 42, "max_items": 0},
