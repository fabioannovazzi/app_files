        "right_label": {"type": "text", "required": true, "max_chars": 42},
        "right_title": {"type": "text", "required": true, "max_chars": 80},
        "right_items": {
          "type": "items",
          "required": true,
          "min_items": 2,
          "max_items": 4,
          "item_template": "templates/items/comparison-point.html",
          "item_fields": {
            "label": {"type": "text", "required": true, "max_chars": 34},
            "body": {"type": "text", "required": true, "max_chars": 115}
          }
        },
        "source_note": {"type": "text", "required": false, "max_chars": 180}
