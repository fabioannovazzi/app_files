          "required": true,
          "min_items": 2,
          "max_items": 4,
          "item_template": "templates/items/metric.html",
          "item_fields": {
            "label": {"type": "text", "required": true, "max_chars": 42},
            "value": {"type": "text", "required": true, "max_chars": 24},
            "detail": {"type": "text", "required": true, "max_chars": 110},
            "tone": {"type": "enum", "required": true, "values": ["neutral", "accent", "analytical", "risk"]}
          }
        },
        "source_note": {"type": "text", "required": false, "max_chars": 180}
      }
    },
