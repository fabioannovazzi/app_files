        "subtitle": {"type": "text", "required": false, "max_chars": 180},
        "source_note": {"type": "text", "required": false, "max_chars": 180}
      }
    },
    {
      "id": "metric-contrast",
      "name": "Metric contrast",
      "narrative_role": "Quantify the gap that changes the decision.",
      "description": "Two to four directly labelled measures with explicit comparison bases.",
      "slide_class": "slide--top",
      "tone_options": ["light", "dark"],
      "headline_slot": "title",
      "density_budget": {"max_total_words": 92, "max_items": 4},
      "typography_budget": {"headline_max_chars": 105, "headline_max_lines": 3, "body_min_px": 18},
      "fragment_support": {"mode": "items", "max_fragments": 4},
      "template": "templates/metric-contrast.html",
      "slots": {
        "eyebrow": {"type": "text", "required": true, "max_chars": 64},
        "title": {"type": "text", "required": true, "max_chars": 105},
        "metrics": {
