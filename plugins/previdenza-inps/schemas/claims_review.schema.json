{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Previdenza INPS claims review",
  "type": "object",
  "required": ["claims", "overall_assessment"],
  "properties": {
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "claim_text",
          "review_label",
          "claim_type",
          "verdict",
          "sources",
          "evidence_dependencies",
          "reasoning_review",
          "period_scope",
          "research_cutoff_date"
        ],
        "properties": {
          "claim_id": {"type": "string"},
          "claim_text": {"type": "string", "minLength": 1},
          "review_label": {"type": "string", "minLength": 1},
          "claim_type": {
            "enum": ["rule", "case_application", "calculation_basis"]
          },
          "verdict": {
            "enum": [
              "supported",
              "partially_supported",
              "not_supported",
              "contradicted",
              "uncertain"
            ]
          },
          "sources": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "source_id",
                "reference",
                "temporal_role",
                "retrieved_at",
                "version_note",
                "support_note"
              ],
              "properties": {
                "source_id": {"type": "string", "minLength": 1},
                "reference": {"type": "string", "minLength": 1},
                "temporal_role": {
                  "enum": [
                    "period_rule",
                    "research_cutoff_authority",
                    "later_interpretive_authority"
                  ]
                },
                "retrieved_at": {"type": "string", "format": "date-time"},
                "version_note": {"type": "string", "minLength": 1},
                "support_note": {"type": "string", "minLength": 1},
                "snapshot_sha256": {
                  "type": ["string", "null"],
                  "pattern": "^[0-9a-f]{64}$"
                }
              }
            }
          },
          "evidence_dependencies": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          },
          "reasoning_review": {"type": "string", "minLength": 1},
          "period_scope": {
            "type": "object",
            "required": ["status", "start", "end", "note"],
            "properties": {
              "status": {"enum": ["confirmed", "open_ended", "unresolved"]},
              "start": {
                "anyOf": [
                  {"type": "string", "format": "date"},
                  {"type": "null"}
                ]
              },
              "end": {
                "anyOf": [
                  {"type": "string", "format": "date"},
                  {"type": "null"}
                ]
              },
              "note": {"type": "string", "minLength": 1}
            }
          },
          "research_cutoff_date": {"type": "string", "format": "date"},
          "later_authority_note": {"type": "string"}
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "claim_type": {
                  "enum": ["case_application", "calculation_basis"]
                }
              }
            },
            "then": {
              "properties": {
                "evidence_dependencies": {"minItems": 1}
              }
            }
          }
        ]
      }
    }
  }
}
