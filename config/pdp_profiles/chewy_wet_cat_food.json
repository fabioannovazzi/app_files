{
  "profile_name": "chewy_wet_cat_food",
  "display_name": "Chewy · Wet Cat Food PDP",
  "retailer": "chewy",
  "base_url": "https://www.chewy.com",
  "category_hints": [
    "cat food/wet food"
  ],
  "category_urls": [
    "https://www.chewy.com/b/wet-food-389"
  ],
  "parent_rules": {
    "min_color_variants": 0,
    "disallow_kits_regex": "",
    "finish_split_tokens": []
  },
  "id_extractors": {
    "parent_from_url_regex": "/dp/(\\d+)",
    "parent_json_paths": [
      "$.sku",
      "$.product.sku",
      "$.product.id",
      "$.id",
      "$.productId"
    ],
    "variant_id_fields": [
      "$.sku",
      "$.id",
      "$.variant_id",
      "$.variantId",
      "$.itemId",
      "$.productId"
    ]
  },
  "blob_sources": {
    "ordered": [
      {
        "type": "script_jsonld",
        "selector": "script[type='application/ld+json']"
      },
      {
        "type": "script_app_state",
        "selector": "script#__NEXT_DATA__, script[type='application/json'][data-state], script[type='application/json'][data-apollo-state], script[id*='apollo'][type='application/json'], script[id*='state'][type='application/json']"
      },
      {
        "type": "dom_fallback",
        "selector": "body"
      }
    ]
  },
  "field_paths": {
    "brand": [
      "$.brand.name",
      "$.brand",
      "$.product.brand.name",
      "$.product.brand",
      "$.manufacturer"
    ],
    "parent_title": [
      "$.name",
      "$.product.name",
      "$.title",
      "$.product.title"
    ],
    "parent_summary": [
      "$.description",
      "$.product.description",
      "$.shortDescription",
      "$.seo.metaDescription"
    ],
    "series_label": [
      "$.product.line",
      "$.product.series",
      "$.series",
      "$.collection"
    ],
    "category_path": [
      "$.categoryPath",
      "$.breadcrumbs[*].name",
      "$.product.categoryPath",
      "$.product.categories[*].name",
      "$.category.name"
    ],
    "variant_list": [
      "$.offers",
      "$.hasVariant",
      "$.variants",
      "$.product.variants",
      "$.skus",
      "$.product.skus"
    ],
    "variant_fields": {
      "variant_id": [
        "$.sku",
        "$.id",
        "$.skuId",
        "$.itemId",
        "$.productId"
      ],
      "shade_name": [
        "$.name",
        "$.title",
        "$.flavor",
        "$.attributes.flavor",
        "$.variationValues.flavor"
      ],
      "size_text": [
        "$.size",
        "$.sizeText",
        "$.netContent",
        "$.attributes.size",
        "$.packageSize",
        "$.variationValues.size"
      ],
      "price": [
        "$.offers.price",
        "$.price",
        "$.pricing.price",
        "$.salePrice",
        "$.currentPrice"
      ],
      "list_price": [
        "$.offers.priceSpecification.price",
        "$.listPrice",
        "$.pricing.listPrice",
        "$.msrp",
        "$.wasPrice"
      ],
      "currency": [
        "$.offers.priceCurrency",
        "$.currency",
        "$.pricing.currency"
      ],
      "barcode": [
        "$.gtin13",
        "$.gtin12",
        "$.gtin",
        "$.upc",
        "$.ean"
      ],
      "swatch_image": [
        "$.swatch.image",
        "$.swatchImage",
        "$.images.swatch",
        "$.variationValues.swatchImage"
      ],
      "hero_image": [
        "$.image",
        "$.images[0]",
        "$.images.primary",
        "$.primaryImage.url"
      ],
      "availability": [
        "$.offers.availability",
        "$.availability",
        "$.inventory.status",
        "$.inStock"
      ]
    }
  },
  "normalization": {
    "brand": {
      "trim": true,
      "collapse_spaces": true
    },
    "shade_name": {
      "trim": true,
      "collapse_spaces": true
    },
    "title": {
      "trim": true,
      "collapse_spaces": true,
      "strip_pack_counts": true
    }
  },
  "validation": {
    "require_brand": true,
    "require_title": true,
    "price_must_be_numeric": false,
    "reject_if_zero_variants": false
  }
}
