{
  "profile_name": "saksfifthavenue_cashmere_sweaters",
  "display_name": "Saks Fifth Avenue · Cashmere Sweaters PDP",
  "retailer": "saksfifthavenue",
  "base_url": "https://www.saksfifthavenue.com",
  "category_hints": [
    "women-s-apparel/sweaters/cashmere"
  ],
  "category_urls": [
    "https://www.saksfifthavenue.com/c/women-s-apparel/sweaters/cashmere"
  ],
  "parent_rules": {
    "min_color_variants": 2,
    "disallow_kits_regex": "(?i)\\b(?:set|sets|duo|duos|bundle|bundles|gift|gifts)\\b",
    "finish_split_tokens": []
  },
  "id_extractors": {
    "parent_from_url_regex": "/product/[^/?#]*?([0-9]{8,})\\.html",
    "parent_json_paths": [
      "$.id",
      "$.productId",
      "$.productID",
      "$.sku"
    ],
    "variant_id_fields": [
      "$.id",
      "$.sku",
      "$.skuId",
      "$.itemId",
      "$.productId"
    ]
  },
  "blob_sources": {
    "ordered": [
      {
        "type": "script_jsonld",
        "selector": "script[type='application/ld+json']"
      },
      {
        "type": "script_app_state",
        "selector": "script#__NEXT_DATA__, script[type='application/json'][data-state], script[type='application/json'][data-apollo-state], script[id*='apollo'][type='application/json'], script[id*='state'][type='application/json']"
      },
      {
        "type": "dom_fallback",
        "selector": "body"
      }
    ]
  },
  "field_paths": {
    "brand": [
      "$.brand.name",
      "$.brand",
      "$.product.brand.name",
      "$.product.brand"
    ],
    "parent_title": [
      "$.name",
      "$.product.name",
      "$.title",
      "$.product.title"
    ],
    "parent_summary": [
      "$.description",
      "$.product.description",
      "$.shortDescription",
      "$.seo.metaDescription"
    ],
    "series_label": [
      "$.collection",
      "$.product.collection",
      "$.product.line"
    ],
    "category_path": [
      "$.categoryPath",
      "$.breadcrumbs[*].name",
      "$.product.categoryPath",
      "$.product.categories[*].name"
    ],
    "variant_list": [
      "$.variants",
      "$.product.variants",
      "$.skus",
      "$.product.skus",
      "$.offers"
    ],
    "variant_fields": {
      "variant_id": [
        "$.id",
        "$.sku",
        "$.skuId",
        "$.itemId",
        "$.productId"
      ],
      "shade_name": [
        "$.shade",
        "$.color",
        "$.name",
        "$.attributes.color"
      ],
      "size_text": [
        "$.size",
        "$.sizeText",
        "$.attributes.size"
      ],
      "price": [
        "$.price",
        "$.offers.price",
        "$.pricing.price"
      ],
      "list_price": [
        "$.listPrice",
        "$.offers.priceSpecification.price",
        "$.pricing.listPrice"
      ],
      "currency": [
        "$.currency",
        "$.offers.priceCurrency",
        "$.pricing.currency"
      ],
      "barcode": [
        "$.gtin13",
        "$.gtin12",
        "$.upc",
        "$.ean",
        "$.barcode"
      ],
      "swatch_image": [
        "$.swatchImage",
        "$.swatch.image",
        "$.image"
      ],
      "hero_image": [
        "$.image",
        "$.images[0]",
        "$.primaryImage.url"
      ],
      "availability": [
        "$.availability",
        "$.offers.availability",
        "$.inventory.status"
      ]
    }
  },
  "normalization": {
    "brand": {
      "trim": true,
      "collapse_spaces": true
    },
    "shade_name": {
      "trim": true,
      "collapse_spaces": true
    },
    "title": {
      "trim": true,
      "collapse_spaces": true,
      "strip_trailing_shade_tokens": true,
      "strip_pack_counts": true
    }
  },
  "validation": {
    "require_brand": true,
    "require_title": true,
    "price_must_be_numeric": false,
    "reject_if_zero_variants": false
  }
}
