# Nightly Codex Refactor & Detector Runner
# ----------------------------------------
# Targets:
#   make -f tools/Makefile.codex nightly          -> run detectors, then all refactors in safe order
#   make -f tools/Makefile.codex detectors        -> run detector-only scanners (never fail the build)
#   make -f tools/Makefile.codex codex-refactors  -> run refactors; default best-effort; configurable gates
#
# Controls (override at CLI, e.g. FAILFAST=1 make -f tools/Makefile.codex codex-refactors):
#   PATHS_FROM   : list of dirs/files/globs for app code (default: modules_to_scan.txt)
#   TESTS_FROM   : list of dirs/files/globs for tests     (default: tests_to_scan.txt)
#   REF_FLAGS    : extra flags passed to ALL refactor scripts (e.g., --model custom-model; defaults come from config)
#   REF_GIT      : '--git-commit' (default) or '' to disable per-script commits
#   FAILFAST     : 1 => stop on first failing script; 0 => keep going (default)
#   STRICT       : 1 => make target fails if any script failed (still runs all)
#   LLM_GATES    : 1 => run tests between LLM steps; 0 => skip those test gates
#   PYTEST       : test command (default: pytest -q)
#
# Example overnight run with logging:
#   mkdir -p logs
#   nohup make -f tools/Makefile.codex nightly > logs/nightly_$(date +%F_%H%M).log 2>&1 &
#
SHELL := /bin/bash
.ONESHELL:
# Paths & flags
TOOLS_DIR  := $(dir $(abspath $(lastword $(MAKEFILE_LIST))))
PYTHON     ?= python
PATHS_FROM ?= $(TOOLS_DIR)modules_to_scan.txt
TESTS_FROM ?= $(TOOLS_DIR)tests_to_scan.txt
REF_FLAGS  ?=
REF_GIT    ?= --git-commit
FAILFAST   ?= 0
STRICT     ?= 0
LLM_GATES  ?= 1
PYTEST     ?= pytest -q

# Detector outputs
REPORT_DIR     ?= reports
VECTORIZE_JSON := $(REPORT_DIR)/vectorize.json
VECTORIZE_TXT  := $(REPORT_DIR)/vectorize.txt
UILOGIC_JSON   := $(REPORT_DIR)/ui_logic.json
UILOGIC_TXT    := $(REPORT_DIR)/ui_logic.txt

.PHONY: nightly detectors codex-refactors

detectors:
	@mkdir -p $(REPORT_DIR)
	@echo ">> Running detectors (will not fail the build)"
	@$(PYTHON) $(TOOLS_DIR)scan_vectorization_candidates.py --paths-from $(PATHS_FROM) \
		--report-out $(VECTORIZE_TXT) --json-out $(VECTORIZE_JSON) || true
	@$(PYTHON) $(TOOLS_DIR)scan_ui_vs_logic_misplacements.py --paths-from $(PATHS_FROM) \
		--ui-roots ui pages app --report-out $(UILOGIC_TXT) --json-out $(UILOGIC_JSON) || true
	@echo ">> Detector reports written to $(REPORT_DIR)/"

codex-refactors:
	@echo ">> Running Codex refactors (FAILFAST=$(FAILFAST), STRICT=$(STRICT), LLM_GATES=$(LLM_GATES))"
	@rc_total=0; \
	run() { cmd="$$1"; echo "==> $$cmd"; eval "$$cmd"; ec=$$?; if [ $$ec -ne 0 ]; then echo "!! failed: $$ec"; rc_total=1; if [ "$(FAILFAST)" = "1" ]; then exit $$ec; fi; fi; }; \
	\
	# 1) Low-risk mechanical edits (detector-only)
	run "$(PYTHON) $(TOOLS_DIR)run_codex_pathlib_refactor.py --paths-from $(PATHS_FROM) $(REF_FLAGS) $(REF_GIT)"; \
	run "$(PYTHON) $(TOOLS_DIR)run_codex_print_to_logging_refactor.py --paths-from $(PATHS_FROM) $(REF_FLAGS) $(REF_GIT)"; \
	run "$(PYTHON) $(TOOLS_DIR)run_codex_except_refactor.py --paths-from $(PATHS_FROM) $(REF_FLAGS) $(REF_GIT)"; \
	run "$(PYTHON) $(TOOLS_DIR)run_codex_streaming_engine_arg_refactor.py --paths-from $(PATHS_FROM) $(REF_FLAGS) $(REF_GIT)"; \
	\
	# 2) Pandas -> Polars leftovers (broad sweep on selected paths)
	run "$(PYTHON) $(TOOLS_DIR)run_codex_pandas_polar_refactor.py --paths-from $(PATHS_FROM) --all $(REF_FLAGS) $(REF_GIT)"; \
	\
	# 3) Polars helpers (detector-only)
	run "$(PYTHON) $(TOOLS_DIR)run_codex_schema_refactor.py --paths-from $(PATHS_FROM) $(REF_FLAGS) $(REF_GIT)"; \
	run "$(PYTHON) $(TOOLS_DIR)run_codex_row_count_refactor.py --paths-from $(PATHS_FROM) $(REF_FLAGS) $(REF_GIT)"; \
	\
	# 4) LLM integration (detector-only). Gate tests between steps if enabled.
	run "$(PYTHON) $(TOOLS_DIR)run_codex_llm_wrapper_refactor.py --paths-from $(PATHS_FROM) $(REF_FLAGS) $(REF_GIT)"; \
	if [ "$(LLM_GATES)" = "1" ]; then echo "==> Test gate after LLM wrapper"; $(PYTEST) || { ec=$$?; echo "!! tests failed: $$ec"; rc_total=1; if [ "$(FAILFAST)" = "1" ]; then exit $$ec; fi; }; fi; \
	run "$(PYTHON) $(TOOLS_DIR)run_codex_llm_naming_params_refactor.py --paths-from $(PATHS_FROM) $(REF_FLAGS) $(REF_GIT)"; \
	if [ "$(LLM_GATES)" = "1" ]; then echo "==> Test gate after LLM naming"; $(PYTEST) || { ec=$$?; echo "!! tests failed: $$ec"; rc_total=1; if [ "$(FAILFAST)" = "1" ]; then exit $$ec; fi; }; fi; \
	\
	# 5) Tests repair (broad sweep but scoped to tests)
	run "$(PYTHON) $(TOOLS_DIR)run_codex_test_repair.py --paths-from $(TESTS_FROM) --all $(REF_FLAGS) $(REF_GIT)"; \
	\
	if [ "$(STRICT)" = "1" ] && [ $$rc_total -ne 0 ]; then exit $$rc_total; else exit 0; fi

nightly: detectors codex-refactors
	@echo "Nightly run complete."

